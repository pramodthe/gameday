# Copy to .env and fill in. All optional for the scoring core + tests.
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# local (default) | insforge
PERSISTENCE=local
INSFORGE_API_KEY=

# Feature flags (stretch integrations)
ENABLE_GUARDRAIL=false
ENABLE_LYZR=false
ENABLE_QDRANT=false

# Optional override of readiness weights (must sum to ~1.0)
# READINESS_WEIGHTS={"sleep":0.30,"fatigue":0.25,"soreness":0.20,"nutrition":0.15,"mood":0.10}

# Comma-separated allowed frontend origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
